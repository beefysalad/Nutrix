// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UnitSystem {
  metric
  imperial
}

enum GoalMode {
  cutting
  maintenance
  bulking
  custom
}

enum MealType {
  breakfast
  lunch
  dinner
  snack
  other
}

enum EntrySource {
  manual
  search
  ai
  telegram
}

enum IntegrationProvider {
  telegram
}

enum IntegrationStatus {
  disconnected
  connected
  error
}

enum AiMealFeedback {
  accurate
  inaccurate
}

model User {
  id                     String                  @id @default(cuid())
  clerkId                String?                 @unique
  name                   String?
  email                  String                  @unique
  emailVerified          DateTime?
  image                  String?
  hashedPassword         String?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  onBoarded              Boolean                 @default(false)
  foods                  Food[]
  goals                  Goal[]
  integrationConnections IntegrationConnection[]
  mealEntries            MealEntry[]
  dailyReports           DailyReport[]
  pendingLinks           PendingLink[]
  profile                UserProfile?
}

model UserProfile {
  id            String     @id @default(cuid())
  userId        String     @unique
  unitSystem    UnitSystem @default(metric)
  aiModel       String     @default("gemini-2.5-flash-lite")
  timezone      String?
  heightCm      Int?
  weightKg      Decimal?   @db.Decimal(6, 2)
  gender        String?
  age           Int?
  activityLevel String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Goal {
  id            String    @id @default(cuid())
  userId        String
  mode          GoalMode  @default(custom)
  dailyCalories Int?
  proteinGrams  Int?
  carbsGrams    Int?
  fatGrams      Int?
  isActive      Boolean   @default(true)
  startsAt      DateTime?
  endsAt        DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isActive])
}

model Food {
  id           String     @id @default(cuid())
  userId       String?
  name         String
  brand        String?
  servingLabel String?
  calories     Int
  proteinGrams Decimal?   @db.Decimal(6, 2)
  carbsGrams   Decimal?   @db.Decimal(6, 2)
  fatGrams     Decimal?   @db.Decimal(6, 2)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  mealItems    MealItem[]
  user         User?      @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([name])
}

model MealEntry {
  id         String          @id @default(cuid())
  userId     String
  loggedAt   DateTime
  mealType   MealType
  notes      String?
  source     EntrySource     @default(manual)
  aiFeedback AiMealFeedback?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  items      MealItem[]
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, loggedAt])
}

model MealItem {
  id               String    @id @default(cuid())
  mealEntryId      String
  foodId           String?
  foodNameSnapshot String
  quantity         Decimal?  @db.Decimal(8, 2)
  unit             String?
  calories         Int
  proteinGrams     Decimal?  @db.Decimal(6, 2)
  carbsGrams       Decimal?  @db.Decimal(6, 2)
  fatGrams         Decimal?  @db.Decimal(6, 2)
  createdAt        DateTime  @default(now())
  food             Food?     @relation(fields: [foodId], references: [id], onDelete: SetNull)
  mealEntry        MealEntry @relation(fields: [mealEntryId], references: [id], onDelete: Cascade)

  @@index([mealEntryId])
  @@index([foodId])
}

model IntegrationConnection {
  id             String              @id @default(cuid())
  userId         String
  provider       IntegrationProvider
  status         IntegrationStatus   @default(disconnected)
  externalUserId String?
  username       String?
  metadata       Json?
  connectedAt    DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  user           User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@index([provider, status])
}

model PendingLink {
  id         String              @id @default(cuid())
  userId     String
  provider   IntegrationProvider
  token      String              @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
  user       User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, provider])
  @@index([provider, expiresAt])
}

model DailyReport {
  id         String   @id @default(cuid())
  userId     String
  reportDate DateTime
  rating     Int?
  note       String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, reportDate])
  @@index([userId, reportDate])
}
